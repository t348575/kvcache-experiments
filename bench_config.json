{
  "model": "meta-llama/Llama-3.2-3B-Instruct",
  "max_model_len": 92000,
  "gpu_mem_util": 0.9,
  "vllm_port": 8000,
  "n_repetitions": 1,
  "server_startup_timeout": 200,
  "output_prefix": "kv_benchmark",
  "flush_mode": false,
  "flush": {
    "num_documents": 2,
    "document_length": 90000,
    "max_inflight_requests": 1
  },
  "long_doc_qa_script": "lmcache-longdoc.py",
  "long_doc_qa_defaults": {
    "--num-documents": "5",
    "--document-length": "10000",
    "--output-len": "1",
    "--repeat-count": "5",
    "--repeat-mode": "random",
    "--max-inflight-requests": "4"
  },
  "sharegpt_dataset_path": "dataset/ShareGPT_V3_unfiltered_cleaned_split.json",
  "sharegpt_defaults": {
    "--num-prompts": "100",
    "--request-rate": "32",
    "--percentile-metrics": "ttft,tpot,itl",
    "--metric-percentiles": "95,99",
    "--output-len": 1
  },
  "configs": [
    {
      "name": "baseline",
      "description": "No CPU offloading, no GPU prefix caching",
      "profile_json": "results_engine_core_0.json",
      "vllm_args": {
        "--no-enable-prefix-caching": null
      },
      "long_doc_qa_args": {
        "--document-length": ["1024", "10240", "40960", "81920"]
      }
    },
    {
      "name": "offloading",
      "description": "vLLM built-in OffloadingConnector",
      "profile_json": "results_engine_core_0.json",
      "vllm_args": {
        "--no-enable-prefix-caching": null,
        "--kv-offloading-backend": "native",
        "--kv-offloading-size": "128",
        "--disable-hybrid-kv-cache-manager": null
      },
      "long_doc_qa_args": {
        "--document-length": ["1024", "10240", "40960", "81920"]
      }
    },
    {
      "name": "llmd",
      "description": "llmd-kv-cache",
      "profile_json": "results_engine_core_0.json",
      "vllm_args": {
        "--no-enable-prefix-caching": null,
        "--kv-transfer-config": {
          "kv_connector": "OffloadingConnector",
          "kv_role": "kv_both",
          "kv_connector_extra_config": {
            "spec_name": "SharedStorageOffloadingSpec",
            "spec_module_path": "llmd_fs_backend.spec",
            "shared_storage_path": "/scratch-node/jkanichai.21435621/llm-d-fs",
            "use_odirect": true
          }
        }
      },
      "long_doc_qa_args": {
        "--document-length": ["1024", "10240", "40960", "81920"]
      }
    },
    {
      "name": "pystorage",
      "description": "storage-kvcache",
      "profile_json": "results_engine_core_0.json",
      "vllm_args": {
        "--no-enable-prefix-caching": null,
        "--kv-offloading-backend": "native",
        "--kv-offloading-size": "128",
        "--disable-hybrid-kv-cache-manager": null
      },
      "long_doc_qa_args": {
        "--document-length": ["1024", "10240", "40960", "81920"]
      }
    }
  ]
}
